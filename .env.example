# Copy this file to `.env` (repo root) and fill in your values.
# `.env` is gitignored; `.env.example` is committed as the template.
#
# The config loader (src/utils/config.py::load_env_file) reads these
# at `python -m src.cli ...` startup, merges them into the process
# environment (without overriding already-exported vars), and
# substitutes ${VAR} / ${VAR:-default} tokens inside
# config/settings.yaml.

# --- MariaDB (PR 3) -----------------------------------------------------------
# Option A — TCP (default). Requires the user to be granted on the
# host you're connecting from (e.g. '%' or '127.0.0.1').
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_USER=trackai
MARIADB_PASSWORD=CHANGE_ME
MARIADB_DATABASE=trackmania_ai

# Option B — Unix socket. When MARIADB_UNIX_SOCKET is set to a
# non-empty value, the adapter uses the socket and ignores
# MARIADB_HOST / MARIADB_PORT. This is how Debian/Ubuntu MariaDB
# defaults for local users — the socket lives at
#   /run/mysqld/mysqld.sock
# and user grants are bound to '@localhost' (socket) not
# '@127.0.0.1' (TCP).
#
# MARIADB_UNIX_SOCKET=/run/mysqld/mysqld.sock

# --- Neo4j (PR 6) -------------------------------------------------------------
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# --- Ingestion (PR 3) ---------------------------------------------------------
# User-Agent is how TMX identifies this client — set `contact:` to an
# email address the TMX admins can use if they need to ask you about
# traffic.
INGEST_USER_AGENT=trackmania-ai-ingest/0.1 (contact: you@example.com)
